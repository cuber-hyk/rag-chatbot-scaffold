# ============================================================
# RAG Chatbot Project Configuration (OPTIONAL)
# ============================================================
#
# This file is OPTIONAL for advanced customization.
#
# QUICK START:
#   Just run `/skill` in Claude Code - no configuration needed!
#   The project will be generated with sensible defaults.
#
# ADVANCED USAGE:
#   If you want to customize before generation:
#   1. Copy this file to: my_custom_config.yaml
#   2. Modify the settings below
#   3. Run: python scripts/generate_project.py my_custom_config.yaml
#
# ALTERNATIVE:
#   Generate the project first, then edit:
#   - config/application.yaml (application settings)
#   - config/providers.yaml (provider settings)
#
# ============================================================

project:
  # Project name (will be used as directory name)
  name: my-rag-chatbot

  # Project description
  description: "A RAG-based chatbot with vector search and network capabilities"

  # Project version
  version: "0.1.0"

# Vector Database Configuration
vector_db:
  # Choose: weaviate, qdrant, pinecone
  provider: weaviate

  # Collection name for documents
  collection_name: documents

  # Embedding model for vector generation
  embedding_model: text-embedding-3-small

  # Pinecone specific (if using pinecone)
  cloud: aws
  region: us-east-1

# LLM Provider Configuration
llm:
  # Choose: openai, anthropic, azure
  # For SiliconCloud/Moonshot: use 'openai' provider with custom base_url
  provider: openai

  # Model name
  model: gpt-4o

  # Base URL (optional, for OpenAI-compatible APIs)
  # SiliconCloud: https://api.siliconflow.cn/v1
  # Moonshot: https://api.moonshot.cn/v1
  # OpenAI: https://api.openai.com/v1 (default)
  base_url: https://api.openai.com/v1

  # Temperature (0.0 - 2.0)
  temperature: 0.7

  # Maximum tokens for generation
  max_tokens: 2048

  # Azure OpenAI specific (if using azure)
  azure_deployment: ""
  azure_endpoint: ""

# Search Tool Configuration
search:
  # Choose: duckduckgo, tavily
  provider: duckduckgo

  # Maximum results to return
  max_results: 5

# Session Management
session:
  # Session TTL in seconds (300 = 5 minutes)
  ttl: 300

# API Configuration
api:
  # API host
  host: "0.0.0.0"

  # API port
  port: 8000

  # API version prefix
  version_prefix: "v1"

  # CORS allowed origins
  cors_origins:
    - "http://localhost:5173"
    - "http://localhost:5174"

# Authentication
# Set API_KEY in .env file to enable authentication
# Leave empty or set to "none" to disable authentication

# Document Parsing
documents:
  # Supported formats: pdf, markdown, word, text
  formats:
    - pdf
    - markdown
    - word
    - text

  # Maximum file size in MB
  max_file_size: 10

  # Chunk size for text splitting
  # SiliconCloud bge-large-zh-v1.5 has 512 token limit
  chunk_size: 400

  # Chunk overlap
  chunk_overlap: 50

# Logging
logging:
  # Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
  level: INFO

  # Log format: json, text
  format: text

# Features (enable/disable features)
features:
  # Enable WebSocket support for real-time chat
  websocket: false

  # Enable streaming responses
  streaming: true

  # Enable document upload
  document_upload: true

  # Enable session management API
  session_api: true

  # Enable health check endpoint
  health_check: true
