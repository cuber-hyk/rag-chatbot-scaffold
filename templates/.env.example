# RAG Chatbot - Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control

# ============== Project Environment ==============
# Options: development, staging, production
ENVIRONMENT=development

# ============== LLM Provider API Keys ==============
# OpenAI-compatible APIs (use OPENAI_API_KEY):
# - SiliconCloud: https://api.siliconflow.cn/v1
# - Moonshot: https://api.moonshot.cn/v1
# - OpenAI: https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude (when llm.provider: anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Azure OpenAI (when llm.provider: azure)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ============== Vector Database API Keys ==============
# Weaviate (when vector_db.provider: weaviate)
# Only required for Weaviate Cloud, not for local instance
WEAVIATE_API_KEY=

# Qdrant (when vector_db.provider: qdrant)
# Only required for Qdrant Cloud, not for local instance
QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333

# Pinecone (when vector_db.provider: pinecone)
PINECONE_API_KEY=your-pinecone-key-here

# ============== Session Storage ==============
# Redis connection URL
REDIS_URL=redis://localhost:6379

# ============== Search Tool API Keys ==============
# Only required if using Tavily (search.provider: tavily in config/providers.yaml)
TAVILY_API_KEY=

# ============== Authentication ==============
# API key for protecting API endpoints
# Leave empty or set to "none" to disable authentication
API_KEY=

# When enabled, requests must include: X-API-Key: <your-api-key>
